# ============================================================
# Moneta 환경 변수 설정 예시
# 이 파일을 복사해 .env 로 저장한 뒤 실제 값을 입력하세요.
# cp .env.example .env
# ============================================================

# ── Google Gemini (분석·리뷰·위키·임베딩) ────────────────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── OpenAI (플롯 추천·생성) ────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Serper (Clio 웹 검색, 선택) ────────────────────
# https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# ── JWT 인증 ───────────────────────────────────────────────
# 랜덤 문자열로 반드시 변경하세요 (예: openssl rand -hex 32)
JWT_SECRET_KEY=change-this-to-a-random-secret

# ── CORS ─────────────────────────────────────────────────
# 허용할 프론트엔드 주소 (쉼표로 여러 개 입력 가능)
ALLOWED_ORIGINS=http://localhost:3000

# ── ChromaDB ─────────────────────────────────────────────
# localhost → 로컬 파일 모드 / 그 외 → HTTP 서버 모드
CHROMA_HOST=localhost
CHROMA_PORT=8800
CHROMA_COLLECTION_NAME=moneta_embeddings

# ── 백엔드 URL (프론트엔드 Next.js rewrite 대상) ──────────────
BACKEND_URL=http://localhost:8000
